# ==============================================================================
# BACKEND (Django) ENVIRONMENTS
# ==============================================================================

# General
DJANGO_READ_DOT_ENV_FILE=True
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-super-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (Postgres)
# For local docker: postgres://debug:debug@postgres:5432/e_commerce
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# Email (Local Dev with Mailpit)
EMAIL_HOST=localhost
EMAIL_PORT=1025

# Google Social Auth
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (For email verification links)
FRONTEND_URL=http://localhost:3000


# ==============================================================================
# FRONTEND (Next.js) ENVIRONMENTS
# ==============================================================================

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Client ID (Must match the one above)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
