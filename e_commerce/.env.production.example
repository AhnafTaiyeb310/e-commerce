# ------------------------------------------------------------------------------
# DJANGO SETTINGS
# ------------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_ALLOWED_HOSTS=api.yourdomain.com,your-app.onrender.com
DJANGO_ADMIN_URL=admin-custom-path/

# ------------------------------------------------------------------------------
# DATABASE & REDIS
# ------------------------------------------------------------------------------
# Render provides DATABASE_URL automatically if linked
DATABASE_URL=postgres://user:password@hostname:5432/dbname
CONN_MAX_AGE=60
REDIS_URL=redis://your-redis-url:6379/0

# ------------------------------------------------------------------------------
# SECURITY (SSL/HTTPS)
# ------------------------------------------------------------------------------
# Set to True once you have HTTPS enabled on your domain
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True

# ------------------------------------------------------------------------------
# EMAIL (Brevo / Anymail / SMTP)
# ------------------------------------------------------------------------------
BREVO_API_KEY=your-brevo-api-key-here
# Optional: BREVO_API_URL=https://api.brevo.com/v3/
DJANGO_DEFAULT_FROM_EMAIL=Your Brand <noreply@yourdomain.com>
DJANGO_SERVER_EMAIL=error-alerts@yourdomain.com
DJANGO_EMAIL_SUBJECT_PREFIX=[Your Brand]

# ------------------------------------------------------------------------------
# CLOUDINARY (Media Storage)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ------------------------------------------------------------------------------
# GOOGLE OAUTH
# ------------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ------------------------------------------------------------------------------
# FRONTEND & SECURITY
# ------------------------------------------------------------------------------
FRONTEND_URL=https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://your-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=https://www.yourdomain.com,https://your-frontend.onrender.com

# URL to redirect users after they click the email verification link
ACCOUNT_EMAIL_CONFIRMATION_ANONYMOUS_REDIRECT_URL=https://www.yourdomain.com/verify-email

# ------------------------------------------------------------------------------
# MONITORING (Sentry)
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Set between 0.0 and 1.0 (e.g. 0.1 for 10% of traces)
SENTRY_TRACES_SAMPLE_RATE=0.1
