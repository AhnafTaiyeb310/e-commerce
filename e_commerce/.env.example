`# ==============================================================================
# BACKEND (Django) - Place these in Render/Production Env
# ==============================================================================

# DJANGO SETTINGS
# ------------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_ALLOWED_HOSTS=api.yourdomain.com,your-app.onrender.com
DJANGO_ADMIN_URL=admin-custom-path/

# DATABASE & REDIS
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@hostname:5432/dbname
CONN_MAX_AGE=60
REDIS_URL=redis://your-redis-url:6379/0

# SECURITY (SSL/HTTPS)
# ------------------------------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True

# EMAIL (Brevo / Anymail)
# ------------------------------------------------------------------------------
# In production, this uses Anymail with Brevo. 
# You MUST verify your sender email in the Brevo dashboard first.
BREVO_API_KEY=your-brevo-api-key-here
DJANGO_DEFAULT_FROM_EMAIL=Your Name <noreply@yourdomain.com>
DJANGO_SERVER_EMAIL=error-alerts@yourdomain.com
DJANGO_EMAIL_SUBJECT_PREFIX=[Your Brand]

# MEDIA STORAGE (Cloudinary)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# GOOGLE LOGIN (Backend)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# FRONTEND CONNECTION & SECURITY
# ------------------------------------------------------------------------------
FRONTEND_URL=https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://your-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=https://www.yourdomain.com,https://your-frontend.onrender.com
ACCOUNT_EMAIL_CONFIRMATION_ANONYMOUS_REDIRECT_URL=https://www.yourdomain.com/verify-email

# MONITORING (Sentry)
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==============================================================================
# FRONTEND (Next.js) - Place these in Vercel/Render Frontend Env
# ==============================================================================

# API CONNECTION
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# GOOGLE LOGIN (Frontend)
# ------------------------------------------------------------------------------
# Usually matches the GOOGLE_CLIENT_ID from the backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
